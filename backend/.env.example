FIELDOPS_ENV=production
FIELDOPS_HOST=0.0.0.0
FIELDOPS_PORT=8765
FIELDOPS_PUBLIC_APP_URL=https://usfieldops.com
FIELDOPS_API_BASE_URL=https://api.usfieldops.com/api
FIELDOPS_ALLOWED_ORIGINS=https://usfieldops.com,https://www.usfieldops.com
FIELDOPS_SERVE_FRONTEND=false
FIELDOPS_RELOAD=false
# Optional runtime storage override:
# FIELDOPS_DATA_DIR=C:\FieldOps\data
# Optional mounted secret paths:
# FIELDOPS_CREDENTIALS_PATH=/secrets/credentials.json
# FIELDOPS_GMAIL_TOKEN_PATH=/secrets/token.json
# FIELDOPS_CALENDAR_TOKEN_PATH=/secrets/calendar_token.json
